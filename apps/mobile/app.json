{
  "expo": {
    "name": "stemtrack-capture",
    "slug": "stemtrack-capture",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./image/stemtrack-logo.png",
    "scheme": "stemtrackcapture",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./image/assets/android-icon-foreground.png",
        "backgroundImage": "./image/assets/android-icon-background.png",
        "monochromeImage": "./image/assets/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./image/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./image/assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
